{
    "_comment": "Create a AWS AMI with Ubuntu",
    "variables": {
        "region": "",
        "source_ami": "",
        "instance_type": "",
        "vpc_id": "",
        "subnet_id": ""
    },
    "_comment1": "packer build -var \"aws_secret_key=foo\" packer.json",
    "_comment2": "packer build -var-file packer-vars.json packer.json",
    "builders": [
        {
            "type": "amazon-ebs",
            "region": "{{user `region`}}",
            "source_ami": "{{user `source_ami`}}",
            "instance_type": "{{user `instance_type`}}",
            "ssh_username": "ubuntu",
            "ami_name": "AWSB2WeekendImage-{{isotime | clean_resource_name}}",
            "vpc_id": "{{user `vpc_id`}}",
            "subnet_id": "{{user `subnet_id`}}",
            "tags": {
                "Name": "AWSB3WeekendImage-{{isotime | clean_resource_name}}"
            }
        }
    ],
    "provisioners": [
        {
            "type": "shell",
            "inline": [
                "sudo apt update -y",
                "sudo apt install unzip jq nginx -y",
                "sudo apt install git -y",
                "sudo git clone https://github.com/chaitanyadurgasoft/website.git",
                "sudo rm -rf /var/www/html/index.nginx-debian.html",
                "sudo cp website/index.html /var/www/html/index.nginx-debian.html",
                "sudo cp website/aws.png /var/www/html/aws.png",
                "sudo cp website/cloud.jpg /var/www/html/cloud.jpg",
                "sudo service nginx start",
                "sudo systemctl enable nginx",
                "curl https://get.docker.com | bash",
                "curl https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip -o awscliv2.zip ",
                "unzip awscliv2.zip",
                "sudo ./aws/install",
                "sudo useradd -m ansibleadmin --shell /bin/bash",
                "sudo usermod -aG sudo ansibleadmin",
                "echo 'ansibleadmin ALL=(ALL) NOPASSWD:ALL'|sudo tee -a /etc/sudoers",
                "sudo mkdir -p /home/ansibleadmin/.ssh",
                "sudo touch /home/ansibleadmin/.ssh/authorized_keys",
                "echo 'ssh-rsa ' |sudo tee /home/ansibleadmin/.ssh/authorized_keys",
                "sudo chown -R ansibleadmin /home/ansibleadmin/"

            ]
        }
    ],
    "post-processors": [
        {
            "type": "manifest",
            "output": "manifest.json"
        }
    ]
}